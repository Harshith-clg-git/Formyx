# ============================================================
# Formyx Backend — .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/
*.log

# Logs from flight sessions
logs/
*.jsonl

# ML model weights (large files — store with Git LFS or separately)
models/
*.pt
*.onnx
*.tflite

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Sensitive config overrides (never commit hardware-specific settings)
config/settings.local.yaml
